# =====================================================
# AI Powered Interview Coach - Server Environment
# =====================================================
# STEPS FOR COLLABORATORS:
# 1. Copy this file and rename it to ".env"
# 2. Fill in all the values below
# 3. NEVER commit the .env file to git
# =====================================================

# Server Port (keep as 5000)
PORT=5000

# App Environment
NODE_ENV=development

# JWT Secret - use any long random string (e.g. generate one at https://randomkeygen.com/)
JWT_SECRET=replace_this_with_a_long_random_secret_string_at_least_32_chars

# Groq AI API Key - get yours free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# No MONGO_URI needed as we use SQLite (database.sqlite)

